{
	"name": "rw-cms",
	"version": "1.0.0",
	"description": "RW portfolio site CMS",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
		"dev:frontend": "npm run dev --workspace=packages/cms",
		"dev:backend": "npm run dev --workspace=packages/api",
		"build": "npm run build --workspaces",
		"build:frontend": "npm run build --workspace=packages/cms",
		"build:backend": "npm run build --workspace=packages/api",
		"start": "npm run start --workspace=packages/api",
		"db:migrate": "npm run db:migrate --workspace=packages/api",
		"db:migrate:status": "npm run db:migrate:status --workspace=packages/api",
		"migrate": "npm run db:migrate --workspace=packages/api",
		"migrate:status": "npm run db:migrate:status --workspace=packages/api",
		"db:seed": "npm run db:seed --workspace=packages/api",
		"seed": "npm run db:seed --workspace=packages/api",
		"docs:api": "npm run docs:api --workspace=packages/api",
		"format": "npx dprint fmt",
		"format:check": "npx dprint check",
		"lint": "oxlint packages/cms/src packages/api/src packages/shared/src",
		"lint:fix": "oxlint --fix packages/cms/src packages/api/src packages/shared/src",
		"lint:all": "npm run lint && npm run build",
		"test": "npm run test --workspaces",
		"deploy": "bash scripts/deploy.sh",
		"precheck": "bash scripts/pre-push-check.sh",
		"prepare": "[ -d .git ] && ln -sf ../../scripts/pre-push-check.sh .git/hooks/pre-push || true"
	},
	"devDependencies": {
		"concurrently": "^8.2.2",
		"oxlint": "^1.58.0",
		"typescript": "^5.3.3"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
