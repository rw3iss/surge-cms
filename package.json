{
	"name": "rw-cms",
	"version": "1.0.0",
	"description": "RW portfolio site CMS",
	"private": true,
	"packageManager": "pnpm@10.28.0",
	"scripts": {
		"dev": "concurrently \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
		"dev:frontend": "pnpm --filter ./packages/cms run dev",
		"dev:backend": "pnpm --filter ./packages/api run dev",
		"build": "pnpm -r run build",
		"build:frontend": "pnpm --filter ./packages/cms run build",
		"build:backend": "pnpm --filter ./packages/api run build",
		"start": "pnpm --filter ./packages/api run start",
		"db:migrate": "pnpm --filter ./packages/api run db:migrate",
		"db:migrate:status": "pnpm --filter ./packages/api run db:migrate:status",
		"migrate": "pnpm --filter ./packages/api run db:migrate",
		"migrate:status": "pnpm --filter ./packages/api run db:migrate:status",
		"db:seed": "pnpm --filter ./packages/api run db:seed",
		"seed": "pnpm --filter ./packages/api run db:seed",
		"docs:api": "pnpm --filter ./packages/api run docs:api",
		"format": "npx dprint fmt --config config/dprint.json",
		"format:check": "npx dprint check --config config/dprint.json",
		"lint": "oxlint -c config/.oxlintrc.json packages/cms/src packages/api/src packages/shared/src",
		"lint:fix": "oxlint -c config/.oxlintrc.json --fix packages/cms/src packages/api/src packages/shared/src",
		"lint:all": "pnpm run lint && pnpm run build",
		"test": "pnpm -r run test",
		"docker:up": "docker compose -f config/docker-compose.yml up -d",
		"docker:down": "docker compose -f config/docker-compose.yml down",
		"docker:build": "docker compose -f config/docker-compose.yml build",
		"deploy": "bash scripts/deploy.sh",
		"precheck": "bash scripts/pre-push-check.sh",
		"prepare": "[ -d .git ] && ln -sf ../../scripts/pre-push-check.sh .git/hooks/pre-push || true"
	},
	"devDependencies": {
		"concurrently": "^8.2.2",
		"oxlint": "^1.58.0",
		"typescript": "^7.0.2"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {
		"@pageloop/client": "^0.7.1",
		"@pageloop/vanilla": "^0.7.1",
		"solid-js": "^1.9.14"
	}
}
