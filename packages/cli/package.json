{
  "name": "@sitesurge/cli",
  "version": "0.1.1",
  "description": "SiteSurge CLI — interactive/non-interactive setup, migrate, seed, doctor, and start for a SiteSurge instance.",
  "license": "GPL-2.0-only",
  "bin": {
    "sitesurge": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/rw3iss/surge-cms#readme",
  "bugs": "https://github.com/rw3iss/surge-cms/issues",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rw3iss/surge-cms.git",
    "directory": "packages/cli"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sitesurge/server": "workspace:^",
    "commander": "^12.1.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
