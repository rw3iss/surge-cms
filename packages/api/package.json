{
  "name": "@rw/cms-api",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:status": "tsx src/db/migrate.ts --status",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "tsx src/db/reset.ts",
    "seed:fonts": "tsx scripts/seed-fonts.ts",
    "sitemap": "tsx scripts/generate-sitemap.ts",
    "docs:api": "tsx scripts/generate-api-docs.ts",
    "lint": "eslint src --ext .ts",
    "test": "vitest --config ../../config/api/vitest.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.975.0",
    "@rw/cms-shared": "file:../shared",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "nanoid": "^5.0.4",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.11.3",
    "sanitize-html": "^2.17.2",
    "sharp": "^0.35.3",
    "stripe": "^22.3.1",
    "winston": "^3.11.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.10.9",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^8.56.0",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
