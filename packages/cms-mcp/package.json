{
    "name": "@sitesurge/mcp",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "bin": {
        "cms-mcp": "dist/index.js"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup --config ../../config/cms-mcp/tsup.config.ts && tsc -p tsconfig.json --emitDeclarationOnly",
        "start": "node dist/index.js",
        "dev": "tsx src/index.ts",
        "typecheck": "tsc --noEmit",
        "test": "vitest --config ../../config/cms-mcp/vitest.config.ts run --passWithNoTests"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@sitesurge/client": "file:../cms-client",
        "@sitesurge/types": "file:../shared",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "tsup": "^8.5.1",
        "tsx": "^4.23.0",
        "typescript": "^7.0.2",
        "vitest": "^4.1.10"
    }
}
