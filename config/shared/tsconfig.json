{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "../../packages/shared/dist",
    "rootDir": "../../packages/shared/src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["../../packages/shared/src/**/*"],
  "exclude": ["../../packages/shared/node_modules", "../../packages/shared/dist"]
}
