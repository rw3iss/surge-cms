{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["ES2022"],
    "outDir": "../../packages/cli/dist",
    "rootDir": "../../packages/cli/src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true
  },
  "include": ["../../packages/cli/src/**/*"],
  "exclude": ["../../packages/cli/node_modules", "../../packages/cli/dist"]
}
