{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "../../packages/cms-client/dist",
        "rootDir": "../../packages/cms-client/src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true
    },
    "include": ["../../packages/cms-client/src/**/*"],
    "exclude": ["../../packages/cms-client/node_modules", "../../packages/cms-client/dist"]
}
